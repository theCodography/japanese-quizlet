generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatar    String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decks          Deck[]
  progress       UserProgress?
  studySessions  StudySession[]
  cardProgress   CardProgress[]
}

model UserProgress {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  cardsStudied   Int      @default(0)
  lessonsCompleted Int    @default(0)
  experiencePoints Int    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Deck {
  id          String   @id @default(uuid())
  title       String
  description String?
  isPublic    Boolean  @default(false)
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  cards       Card[]
  studySessions StudySession[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Card {
  id         String   @id @default(uuid())
  deckId     String
  deck       Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  term       String
  definition String
  example    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  progress   CardProgress[]
}

model CardProgress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  rating    String?
  starred   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, cardId])
  @@index([userId])
}

model StudySession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  deckId    String
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  score     Int      @default(0)
  createdAt DateTime @default(now())
}

model GrammarLesson {
  id          String   @id @default(uuid())
  title       String
  structure   String
  meaning     String
  explanation String?
  example     String
  example2    String?
  example3    String?
  level       String
  textbook    String   @default("")
  lesson      Int?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([level])
  @@index([textbook, lesson])
}

model VocabularyLesson {
  id        String   @id @default(uuid())
  word      String
  reading   String
  meaning   String
  example   String?
  audioUrl  String?
  level     String
  createdAt DateTime @default(now())
}
