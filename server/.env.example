# 1. Chuỗi kết nối Database Postgres (Transaction pooler - port 6543)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Direct URL (không qua pgBouncer) - Dùng cho migrations (port 5432)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# 2. Project URL của Supabase
SUPABASE_URL="https://your-project.supabase.co"

# 3. Anon Key của Supabase
SUPABASE_ANON_KEY="your-supabase-anon-key"

# 4. JWT Secret (Dùng để ký và xác thực JWT token)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# 5. Server port (Render tự set, không cần điền)
PORT=3000

# 6. Node environment
NODE_ENV="production"

# 7. Các origin được phép gọi API (phân cách bằng dấu phẩy)
# Ví dụ: https://japan-quizlet.vercel.app,https://japan-quizlet-git-main.vercel.app
ALLOWED_ORIGINS="https://japanese-quizlet.vercel.app"
